{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "module": "amd",
        "target": "es5",
        "moduleResolution": "node",
        "baseUrl": "src",
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noImplicitThis": true,
        "alwaysStrict": true
    }
}
{
    "name": "souza-frontend",
    "version": "1.0.0",
    "description": "Front-end da Souza.eti.br.",
    "main": "index.js",
    "repository": {
        "type": "git",
        "url": "git://github.com/souza-eti-br/souza-frontend.git"
    },
    "scripts": {
        "clean": "del /s/q dist && rmdir /s/q dist",
        "build-src": "tsc --build tsconfig.json",
        "build-web": "xcopy web dist /e/h/y",
        "build-all": "npm run build-src && npm run build-web",
        "rebuild": "npm run clean && npm run build-all"
    },
    "author": "Alan Moraes Souza",
    "license": "MIT",
    "homepage": "https://www.souza.eti.br/",
    "dependencies": {
        "typescript": "^4.1.5"
    }
}
